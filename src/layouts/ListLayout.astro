---
import Container from "../components/layouts/Container.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import PageTitle from "../components/ui/PageTitle.astro";
import BaseLayout from "./BaseLayout.astro";
import FilterableGrid from "../components/content/FilterableGrid.astro";

import type { ContentEntry, WithMeta } from "../types";

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    entries: WithMeta<ContentEntry>[];
    jsonLd?: Record<string, unknown>[];
}

const { title, description = "", entries, ogImage, jsonLd } = Astro.props;

const collection = entries[0]?.collection;
---

<BaseLayout {title} {description} {jsonLd}>
    <Container class="py-12">
        <PageTitle {title} />
        {
            description && (
                <p class="mt-4 px-4 text-lg text-gray-600 sm:px-6 md:px-0 dark:text-gray-400">
                    {description}
                </p>
            )
        }

        {
            entries.length === 0 ? (
                <EmptyState
                    title="这里还什么都没有…"
                    message="很快会有新内容,欢迎稍后再来!"
                />
            ) : (
                <FilterableGrid {entries} />
            )
        }
    </Container>
</BaseLayout>
