---
import { getCollection, render } from "astro:content";
import Article from "../components/content/Article.astro";
import InfoPanel from "../components/content/InfoPanel.astro";
import PostMeta from "../components/content/PostMeta.astro";
import PostNavigation from "../components/content/PostNavigation.astro";
import Prose from "../components/content/Prose.astro";
import RelatedContent from "../components/content/RelatedContent.astro";
import ToC from "../components/content/ToC/ToC.astro";
import MediumZoom from "../components/integrations/MediumZoom.astro";
import { Icon } from "astro-icon/components";
import type { ContentEntry, WithMeta } from "../types";
import BaseLayout from "./BaseLayout.astro";
import {
    articleStructuredData,
    collectionLabels,
    collectionLinks,
    displayName,
    getRelatedEntries,
} from "../utils/contentEnhancements";
import { attachMeta } from "../utils/meta";
import { SITE_SETTINGS } from "../site.config";

interface Props {
    entry: WithMeta<ContentEntry>;
}

const { entry } = Astro.props;

const { Content, headings } = await render(entry);

// SEO：结构化数据 + 面包屑
const siteHref = Astro.site?.href ?? "/";
const ogImage = new URL(entry.data.image.src, Astro.site).href;
const structuredData =
    entry.collection === "travel" ||
    entry.collection === "movies" ||
    entry.collection === "tv"
        ? articleStructuredData(
              entry as any,
              siteHref,
              ogImage,
              SITE_SETTINGS.owner,
          )
        : [];
const crumbLabel =
    collectionLabels[entry.collection as keyof typeof collectionLabels];
const crumbLink =
    collectionLinks[entry.collection as keyof typeof collectionLinks];
const crumbName = ["travel", "movies", "tv"].includes(entry.collection)
    ? displayName(entry as any)
    : entry.data.title;

const allPostsInCollection = await getCollection(entry.collection);

const postIndex = allPostsInCollection.findIndex((e) => e.id === entry.id);
const prevPost = allPostsInCollection[postIndex + 1];
const nextPost = allPostsInCollection[postIndex - 1];
const relatedPosts = getRelatedEntries(
    entry,
    allPostsInCollection as ContentEntry[],
    6,
).map((post) => attachMeta(post));
---

<BaseLayout
    title={entry.data.title}
    description={entry.data.description}
    image={entry.data.image.src}
    article={{
        publishedTime: entry.data.pubDate,
        modifiedTime: entry.data.updatedDate,
        tags: entry.data.tags,
    }}
    jsonLd={structuredData}
>
    <MediumZoom />

    {
        headings.length > 0 && (
            <>
                <button
                    id="open-toc-button"
                    aria-label="打开目录"
                    class="fixed top-24 right-6 z-30 flex size-12 cursor-pointer items-center justify-center rounded-lg bg-neutral-900 text-white shadow-sm transition duration-250 ease-out hover:bg-neutral-700 active:scale-95 dark:bg-neutral-100 dark:text-black dark:hover:bg-neutral-50"
                >
                    <Icon name="lucide:list" class="size-6" />
                </button>
            </>
        )
    }

    <Article>
        <div data-pagefind-body>
            {
                crumbLabel && (
                    <nav aria-label="面包屑" class="mb-6 text-sm text-neutral-500 dark:text-neutral-400">
                        <a href="/" class="hover:underline">首页</a>
                        <span class="mx-1.5">/</span>
                        <a href={crumbLink} class="hover:underline">{crumbLabel}</a>
                        <span class="mx-1.5">/</span>
                        <span class="text-neutral-700 dark:text-neutral-300">{crumbName}</span>
                    </nav>
                )
            }
            <!-- Header -->
            <PostMeta {entry} />

            <InfoPanel {entry} />

            <!-- Content -->
            <Prose>
                <Content />
            </Prose>
        </div>
        <RelatedContent items={relatedPosts} />
        <!-- Post Navigation -->
        <PostNavigation {prevPost} {nextPost} />
    </Article>

    {headings.length > 0 && <ToC headings={headings} />}
</BaseLayout>

<script>
    const tocButton = document.getElementById("open-toc-button");
    const tocSidebar = document.getElementById("toc-sidebar");
    const closeTocButton = document.getElementById("close-toc-button");

    if (tocButton && tocSidebar && closeTocButton) {
        const closeToc = () => {
            tocSidebar.classList.add("translate-x-full");
            document.dispatchEvent(new CustomEvent("hide-overlay"));
        };

        const openToc = () => {
            tocSidebar.classList.remove("translate-x-full");
            document.dispatchEvent(new CustomEvent("show-overlay"));
        };

        const onKeydown = (event: KeyboardEvent) => {
            if (
                event.key === "Escape" &&
                !tocSidebar.classList.contains("translate-x-full")
            ) {
                closeToc();
            }
        };

        const onSidebarClick = (event: MouseEvent) => {
            if (
                event.target instanceof HTMLAnchorElement &&
                event.target.hasAttribute("href")
            ) {
                closeToc();
            }
        };

        tocButton.addEventListener("click", openToc);
        closeTocButton.addEventListener("click", closeToc);
        document.addEventListener("overlay-clicked", closeToc);
        document.addEventListener("keydown", onKeydown);
        tocSidebar.addEventListener("click", onSidebarClick);
    }
</script>
