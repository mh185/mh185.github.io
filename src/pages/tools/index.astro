---
import { getCollection } from "astro:content";
import Container from "../../components/layouts/Container.astro";
import PageTitle from "../../components/ui/PageTitle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getEntryScore } from "../../utils/contentEnhancements";
import { cardImageSrc } from "../../utils/images";

const [travel, movies, tv] = await Promise.all([
    getCollection("travel", ({ data }) => !data.draft),
    getCollection("movies", ({ data }) => !data.draft),
    getCollection("tv", ({ data }) => !data.draft),
]);

const entries = [...travel, ...movies, ...tv]
    .map((entry) => ({
        key: `${entry.collection}/${entry.id}`,
        collection: entry.collection,
        id: entry.id,
        title: entry.data.title,
        description: entry.data.description,
        image: cardImageSrc(entry.data.image.src),
        href: `/${entry.collection}/${entry.id}`,
        tags: entry.data.tags,
        score: getEntryScore(entry),
    }))
    .sort((a, b) => b.score - a.score);

const tagCounts = new Map<string, number>();
for (const entry of entries) {
    for (const tag of entry.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
}

const popularTags = [...tagCounts.entries()]
    .filter(([, count]) => count >= 2)
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .slice(0, 32)
    .map(([tag]) => tag);
---

<BaseLayout title="实用工具" description="随机推荐、旅游预算计算器和旅行/观影偏好测评。">
    <Container class="space-y-12 py-12">
        <PageTitle title="实用工具" />
        <p class="max-w-3xl text-lg text-neutral-600 dark:text-neutral-400">
            用工具快速从内容库里找到想去的景点、想看的电影和适合追的剧, 也可以先估一版旅行预算。
        </p>

        <section class="rounded-xl border border-neutral-200 p-6 dark:border-neutral-800">
            <div class="mb-6">
                <h2 class="text-2xl font-bold">随机推荐器</h2>
                <p class="mt-2 text-neutral-600 dark:text-neutral-400">
                    不知道看哪篇时, 按栏目和标签随机抽一个。
                </p>
            </div>
            <div class="grid gap-3 md:grid-cols-[180px_1fr_auto]">
                <select id="random-collection" class="rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    <option value="">全部栏目</option>
                    <option value="travel">旅游</option>
                    <option value="movies">电影</option>
                    <option value="tv">电视剧</option>
                </select>
                <select id="random-tag" class="rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    <option value="">全部标签</option>
                    {popularTags.map((tag) => <option value={tag}>{tag}</option>)}
                </select>
                <button id="random-button" class="rounded-lg bg-neutral-900 px-5 py-2 font-semibold text-white transition hover:bg-neutral-700 dark:bg-neutral-100 dark:text-black dark:hover:bg-neutral-300">
                    随机一下
                </button>
            </div>
            <div id="random-result" class="mt-6"></div>
        </section>

        <section class="rounded-xl border border-neutral-200 p-6 dark:border-neutral-800">
            <div class="mb-6">
                <h2 class="text-2xl font-bold">旅游预算计算器</h2>
                <p class="mt-2 text-neutral-600 dark:text-neutral-400">
                    输入人数、天数和主要花费, 快速估算总预算和人均预算。
                </p>
            </div>
            <div class="grid gap-4 md:grid-cols-4">
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">人数</span>
                    <input id="budget-people" type="number" min="1" value="2" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">天数</span>
                    <input id="budget-days" type="number" min="1" value="3" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">往返交通/人</span>
                    <input id="budget-transport" type="number" min="0" value="800" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">住宿/晚/间</span>
                    <input id="budget-hotel" type="number" min="0" value="400" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">餐饮/人/天</span>
                    <input id="budget-food" type="number" min="0" value="120" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">门票/人</span>
                    <input id="budget-ticket" type="number" min="0" value="300" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">市内交通/人/天</span>
                    <input id="budget-local" type="number" min="0" value="60" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
                <label class="block">
                    <span class="mb-1 block text-sm text-neutral-500">机动预算</span>
                    <input id="budget-extra" type="number" min="0" value="500" class="budget-input w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950" />
                </label>
            </div>
            <div class="mt-6 grid gap-4 md:grid-cols-3">
                <div class="rounded-lg bg-neutral-50 p-4 dark:bg-neutral-900">
                    <div class="text-sm text-neutral-500">总预算</div>
                    <div id="budget-total" class="mt-1 text-2xl font-bold">-</div>
                </div>
                <div class="rounded-lg bg-neutral-50 p-4 dark:bg-neutral-900">
                    <div class="text-sm text-neutral-500">人均预算</div>
                    <div id="budget-per-person" class="mt-1 text-2xl font-bold">-</div>
                </div>
                <div class="rounded-lg bg-neutral-50 p-4 dark:bg-neutral-900">
                    <div class="text-sm text-neutral-500">预算等级</div>
                    <div id="budget-level" class="mt-1 text-2xl font-bold">-</div>
                </div>
            </div>
        </section>

        <section class="rounded-xl border border-neutral-200 p-6 dark:border-neutral-800">
            <div class="mb-6">
                <h2 class="text-2xl font-bold">旅行/观影偏好测评</h2>
                <p class="mt-2 text-neutral-600 dark:text-neutral-400">
                    选几个偏好, 从现有内容里推荐更适合你的景点、电影或剧。
                </p>
            </div>
            <div class="grid gap-3 md:grid-cols-4">
                <select id="quiz-type" class="rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    <option value="">都可以</option>
                    <option value="travel">想出去玩</option>
                    <option value="movies">想看电影</option>
                    <option value="tv">想追剧</option>
                </select>
                <select id="quiz-mood" class="rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    <option value="classic">经典口碑</option>
                    <option value="nature">自然风景</option>
                    <option value="city">城市休闲</option>
                    <option value="sci-fi">科幻烧脑</option>
                    <option value="crime">犯罪悬疑</option>
                    <option value="family">亲子轻松</option>
                </select>
                <select id="quiz-time" class="rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    <option value="short">时间不多</option>
                    <option value="medium">半天到周末</option>
                    <option value="long">想深度体验</option>
                </select>
                <button id="quiz-button" class="rounded-lg bg-neutral-900 px-5 py-2 font-semibold text-white transition hover:bg-neutral-700 dark:bg-neutral-100 dark:text-black dark:hover:bg-neutral-300">
                    生成推荐
                </button>
            </div>
            <div id="quiz-result" class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2"></div>
        </section>
    </Container>
</BaseLayout>

<script id="tool-data" type="application/json" set:html={JSON.stringify(entries)} />

<script>
    const entries = JSON.parse(document.getElementById("tool-data")?.textContent || "[]");
    const labels = { travel: "旅游", movies: "电影", tv: "电视剧" };

    const card = (entry) => `
        <a href="${entry.href}" class="grid gap-4 rounded-xl border border-neutral-200 p-4 transition hover:bg-neutral-50 dark:border-neutral-800 dark:hover:bg-neutral-900 md:grid-cols-[140px_1fr]">
            <img src="${entry.image}" alt="${entry.title}" class="aspect-video w-full rounded-lg object-cover" loading="lazy" />
            <div>
                <div class="text-xs font-semibold text-neutral-500">${labels[entry.collection] ?? ""}</div>
                <h3 class="mt-1 line-clamp-2 font-bold">${entry.title}</h3>
                <p class="mt-2 line-clamp-2 text-sm text-neutral-600 dark:text-neutral-400">${entry.description}</p>
                <div class="mt-3 flex flex-wrap gap-2">${entry.tags.slice(0, 4).map((tag) => `<span class="rounded-full bg-neutral-100 px-2 py-1 text-xs dark:bg-neutral-800">${tag}</span>`).join("")}</div>
            </div>
        </a>
    `;

    const pickRandom = () => {
        const collection = document.getElementById("random-collection")?.value || "";
        const tag = document.getElementById("random-tag")?.value || "";
        const pool = entries.filter((entry) => {
            const collectionOk = !collection || entry.collection === collection;
            const tagOk = !tag || entry.tags.includes(tag);
            return collectionOk && tagOk;
        });
        const result = document.getElementById("random-result");
        if (!result) return;
        if (!pool.length) {
            result.innerHTML = `<div class="rounded-lg border border-dashed border-neutral-300 p-6 text-neutral-500 dark:border-neutral-700">没有匹配内容, 换个筛选条件试试。</div>`;
            return;
        }
        const entry = pool[Math.floor(Math.random() * pool.length)];
        result.innerHTML = card(entry);
    };

    const numberValue = (id) => Math.max(0, Number(document.getElementById(id)?.value || 0));
    const updateBudget = () => {
        const people = Math.max(1, numberValue("budget-people"));
        const days = Math.max(1, numberValue("budget-days"));
        const nights = Math.max(0, days - 1);
        const rooms = Math.ceil(people / 2);
        const total =
            people * numberValue("budget-transport") +
            rooms * nights * numberValue("budget-hotel") +
            people * days * numberValue("budget-food") +
            people * numberValue("budget-ticket") +
            people * days * numberValue("budget-local") +
            numberValue("budget-extra");
        const per = Math.round(total / people);
        const level = per < 1500 ? "轻预算" : per < 3500 ? "舒适型" : "高预算";
        document.getElementById("budget-total").textContent = `¥${Math.round(total).toLocaleString("zh-CN")}`;
        document.getElementById("budget-per-person").textContent = `¥${per.toLocaleString("zh-CN")}`;
        document.getElementById("budget-level").textContent = level;
    };

    const quizKeywords = {
        classic: ["高分", "经典", "精选", "世界遗产", "5A"],
        nature: ["山", "湖", "云海", "自然", "海岛", "登山", "峡谷"],
        city: ["城市", "古城", "古镇", "园林", "夜景", "上海", "北京"],
        "sci-fi": ["科幻", "烧脑", "科技", "三体", "黑镜", "未来"],
        crime: ["犯罪", "悬疑", "黑帮", "心理", "法庭"],
        family: ["动画", "亲子", "家庭", "轻松", "周末"],
    };

    const runQuiz = () => {
        const type = document.getElementById("quiz-type")?.value || "";
        const mood = document.getElementById("quiz-mood")?.value || "classic";
        const time = document.getElementById("quiz-time")?.value || "short";
        const keywords = quizKeywords[mood] || [];
        const preferred = entries
            .filter((entry) => !type || entry.collection === type)
            .map((entry) => {
                const text = `${entry.title} ${entry.description} ${entry.tags.join(" ")}`;
                let score = entry.score;
                for (const word of keywords) {
                    if (text.includes(word)) score += 5000;
                }
                if (time === "short" && (entry.collection === "movies" || entry.tags.some((tag) => tag.includes("城市")))) score += 1200;
                if (time === "long" && (entry.collection === "tv" || entry.tags.some((tag) => tag.includes("山") || tag.includes("世界遗产")))) score += 1200;
                return { entry, score };
            })
            .sort((a, b) => b.score - a.score)
            .slice(0, 6)
            .map(({ entry }) => entry);
        document.getElementById("quiz-result").innerHTML = preferred.map(card).join("");
    };

    document.getElementById("random-button")?.addEventListener("click", pickRandom);
    document.getElementById("quiz-button")?.addEventListener("click", runQuiz);
    document.querySelectorAll(".budget-input").forEach((input) => input.addEventListener("input", updateBudget));
    pickRandom();
    updateBudget();
    runQuiz();
</script>
