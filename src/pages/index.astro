---
import { getCollection } from "astro:content";
import Container from "../components/layouts/Container.astro";
import ContentGrid from "../components/layouts/sections/ContentGrid.astro";
import FeaturedContent from "../components/layouts/sections/FeaturedContent.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { attachMeta } from "../utils/meta";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const allProjects = await getCollection("projects", ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const sortedProjects = allProjects.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPosts = sortedPosts.slice(0, 3).map((post) => attachMeta(post));
const latestProjects = sortedProjects
    .slice(0, 2)
    .map((project) => attachMeta(project));

const featured = [...allPosts, ...allProjects]
    .filter((item) => item.data.featured !== undefined)
    .sort((a, b) => (a.data.featured ?? 0) - (b.data.featured ?? 0));

const hasContent =
    featured.length > 0 || latestPosts.length > 0 || latestProjects.length > 0;
---

<BaseLayout
    title="我的博客"
    description="记录想法,分享我正在学习的东西。"
>
    <Container class="space-y-24 py-12">
        {
            hasContent ? (
                <>
                    {featured.length > 0 && (
                        <FeaturedContent items={featured} />
                    )}

                    {latestPosts.length > 0 && (
                        <ContentGrid
                            title="最新文章"
                            href="/blog"
                            viewAllText="查看全部文章 →"
                            items={latestPosts}
                        />
                    )}

                    {latestProjects.length > 0 && (
                        <ContentGrid
                            title="最新项目"
                            href="/projects"
                            viewAllText="查看全部项目 →"
                            items={latestProjects}
                            class="grid grid-cols-1 gap-8 md:grid-cols-2"
                        />
                    )}
                </>
            ) : (
                <EmptyState
                    title="这里还什么都没有…"
                    message="很快会有新内容,欢迎稍后再来!"
                />
            )
        }
    </Container>
</BaseLayout>
