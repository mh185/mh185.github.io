---
import { getCollection } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import { attachMeta } from "../../utils/meta";

const posts = (await getCollection("movies", ({ data }) => !data.draft))
    // 先按榜单名次升序（无名次的排在最后），名次相同再按发布日期倒序
    .sort((a, b) => {
        const ra = a.data.rank ?? Infinity;
        const rb = b.data.rank ?? Infinity;
        if (ra !== rb) return ra - rb;
        return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    })
    .map((p) => attachMeta(p));
---

<ListLayout
    title="电影推荐"
    description="好看的电影推荐与影评,恐怖、悬疑、爱情各种类型,帮你挑到不踩雷的好片。"
    entries={posts}
/>
