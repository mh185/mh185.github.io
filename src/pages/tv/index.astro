---
import { getCollection } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import { attachMeta } from "../../utils/meta";

const posts = (await getCollection("tv", ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map((p) => attachMeta(p));
---

<ListLayout
    title="电视剧推荐"
    description="值得追的电视剧、美剧推荐与剧评,总有一部让你上头。"
    entries={posts}
/>
