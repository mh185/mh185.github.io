---
import { getCollection } from "astro:content";
import Container from "../components/layouts/Container.astro";
import PageTitle from "../components/ui/PageTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const [travel, movies, tv] = await Promise.all([
    getCollection("travel", ({ data }) => !data.draft),
    getCollection("movies", ({ data }) => !data.draft),
    getCollection("tv", ({ data }) => !data.draft),
]);

const rankOf = (e: any) =>
    typeof e.data.rank === "number" ? e.data.rank : 9999;

// 为每篇文章取一个简短标签名
const shortLabel = (e: any) => {
    const t: string = e.data.title;
    if (e.collection === "travel") {
        const m = t.match(/第\d+名[:：]\s*(.+?)(?:深度攻略|攻略|$)/);
        if (m) return m[1];
        return t.replace(/^中国必去景点第\d+名[:：]?/, "").split(/[,，:：]/)[0];
    }
    const m = t.match(/《([^》]+)》/);
    return m ? m[1] : t.split(/[,，:：]/)[0];
};

const toChip = (e: any) => ({
    key: `${e.collection}/${e.id}`,
    rank: rankOf(e),
    label: shortLabel(e),
    href: `/${e.collection}/${e.id}`,
});

const groups = [
    {
        id: "travel",
        name: "必去景点",
        total: 100,
        chips: travel.map(toChip).sort((a, b) => a.rank - b.rank),
    },
    {
        id: "movies",
        name: "必看电影",
        total: 100,
        chips: movies.map(toChip).sort((a, b) => a.rank - b.rank),
    },
    {
        id: "tv",
        name: "必看电视剧",
        total: 100,
        chips: tv.map(toChip).sort((a, b) => a.rank - b.rank),
    },
];
---

<BaseLayout
    title="打卡"
    description="勾选你已经去过的景点、看过的电影和追完的剧，记录属于自己的进度。"
>
    <Container class="py-12">
        <PageTitle title="打卡清单" />
        <p class="mt-4 max-w-3xl text-lg text-neutral-600 dark:text-neutral-400">
            把你<strong>去过的景点、看过的电影、追完的剧</strong>点亮吧。进度只保存在当前浏览器里，随时回来继续。
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-4 rounded-xl border border-neutral-200 p-4 dark:border-neutral-800">
            <div class="text-sm text-neutral-600 dark:text-neutral-400">
                总进度 <span class="checkin-total-done font-bold text-neutral-900 dark:text-neutral-100">0</span> / {groups.reduce((n, g) => n + g.total, 0)}
            </div>
            <button class="checkin-reset ml-auto rounded-lg border border-neutral-200 px-3 py-1.5 text-sm font-medium text-neutral-600 transition hover:bg-neutral-50 dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-900">
                清空全部打卡
            </button>
        </div>

        {
            groups.map((g) => (
                <section class="mt-10" data-group={g.id}>
                    <div class="mb-3 flex items-baseline justify-between gap-3">
                        <h2 class="text-2xl font-bold">{g.name}</h2>
                        <div class="text-sm text-neutral-500">
                            已打卡 <span class="checkin-count font-bold text-green-600 dark:text-green-400" data-group={g.id}>0</span> / {g.total}
                        </div>
                    </div>
                    <div class="mb-5 h-2 overflow-hidden rounded-full bg-neutral-200 dark:bg-neutral-800">
                        <div class="checkin-bar h-full rounded-full bg-green-500 transition-[width] duration-300" data-group={g.id} style="width:0%"></div>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {g.chips.map((c) => (
                            <button
                                type="button"
                                class="checkin-chip group inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-white px-3 py-1.5 text-sm text-neutral-700 transition hover:border-green-400 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300"
                                data-key={c.key}
                                data-group={g.id}
                                title={c.label}
                            >
                                <span class="checkin-tick flex h-4 w-4 items-center justify-center rounded-full border border-neutral-300 text-[10px] leading-none dark:border-neutral-600">
                                    <span class="checkin-tick-mark hidden">✓</span>
                                </span>
                                <span class="text-neutral-400 tabular-nums">{c.rank <= 100 ? c.rank : ""}</span>
                                <span>{c.label}</span>
                            </button>
                        ))}
                    </div>
                </section>
            ))
        }

        <p class="mt-12 text-sm text-neutral-500">
            提示：想边看边勾，可在<a href="/travel" class="underline">景点</a>、<a href="/movies" class="underline">电影</a>、<a href="/tv" class="underline">电视剧</a>列表里挑选阅读，再回来打卡。
        </p>
    </Container>
</BaseLayout>

<script>
    const KEY = "checkinDone";
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".checkin-chip"));

    const load = (): Set<string> => {
        try {
            return new Set(JSON.parse(localStorage.getItem(KEY) || "[]"));
        } catch {
            return new Set();
        }
    };
    const save = (set: Set<string>) =>
        localStorage.setItem(KEY, JSON.stringify([...set]));

    const paintChip = (chip: HTMLElement, on: boolean) => {
        const tick = chip.querySelector<HTMLElement>(".checkin-tick");
        const mark = chip.querySelector<HTMLElement>(".checkin-tick-mark");
        chip.classList.toggle("border-green-500", on);
        chip.classList.toggle("bg-green-50", on);
        chip.classList.toggle("dark:bg-green-900/30", on);
        chip.classList.toggle("dark:border-green-600", on);
        chip.classList.toggle("text-green-800", on);
        chip.classList.toggle("dark:text-green-300", on);
        tick?.classList.toggle("bg-green-500", on);
        tick?.classList.toggle("border-green-500", on);
        tick?.classList.toggle("text-white", on);
        mark?.classList.toggle("hidden", !on);
    };

    const refreshCounts = (set: Set<string>) => {
        const groups: Record<string, number> = {};
        chips.forEach((chip) => {
            const g = chip.dataset.group!;
            groups[g] = groups[g] || 0;
            if (set.has(chip.dataset.key!)) groups[g]++;
        });
        document.querySelectorAll<HTMLElement>(".checkin-count").forEach((el) => {
            el.textContent = String(groups[el.dataset.group!] || 0);
        });
        document.querySelectorAll<HTMLElement>(".checkin-bar").forEach((el) => {
            const g = el.dataset.group!;
            const total = chips.filter((c) => c.dataset.group === g).length || 1;
            el.style.width = `${Math.round(((groups[g] || 0) / total) * 100)}%`;
        });
        const totalDone = document.querySelector<HTMLElement>(".checkin-total-done");
        if (totalDone) totalDone.textContent = String(set.size);
    };

    const render = () => {
        const set = load();
        chips.forEach((chip) => paintChip(chip, set.has(chip.dataset.key!)));
        refreshCounts(set);
    };

    chips.forEach((chip) => {
        chip.addEventListener("click", () => {
            const set = load();
            const k = chip.dataset.key!;
            if (set.has(k)) set.delete(k);
            else set.add(k);
            save(set);
            paintChip(chip, set.has(k));
            refreshCounts(set);
        });
    });

    document.querySelector(".checkin-reset")?.addEventListener("click", () => {
        if (!confirm("确定清空全部打卡记录吗？此操作不可撤销。")) return;
        save(new Set());
        render();
    });

    render();
</script>
