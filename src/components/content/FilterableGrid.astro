---
import Card from "./Card.astro";
import type { ContentEntry, WithMeta } from "../../types";
import { getEntryScore, getTravelRank } from "../../utils/contentEnhancements";

interface Props {
    entries: WithMeta<ContentEntry>[];
}

const { entries } = Astro.props;
const hasTravelRanks = entries.some((entry) => getTravelRank(entry) !== undefined);

const tagCounts = new Map<string, number>();
for (const entry of entries) {
    for (const tag of entry.data.tags) {
        tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
}

const tags = [...tagCounts.entries()]
    .filter(([, count]) => count >= 2)
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .slice(0, 24);
---

<section class="filterable-list">
    <div class="mb-8 rounded-xl border border-neutral-200 p-4 dark:border-neutral-800">
        <div class="grid gap-3 md:grid-cols-[1fr_220px_180px]">
            <label class="block">
                <span class="mb-1 block text-sm font-medium text-neutral-600 dark:text-neutral-400">搜索</span>
                <input
                    class="filter-search w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 outline-none transition focus:border-neutral-500 dark:border-neutral-700 dark:bg-neutral-950"
                    type="search"
                    placeholder="输入标题、描述或标签"
                />
            </label>
            <label class="block">
                <span class="mb-1 block text-sm font-medium text-neutral-600 dark:text-neutral-400">标签</span>
                <select class="filter-tag w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    <option value="">全部标签</option>
                    {tags.map(([tag, count]) => <option value={tag}>{tag} ({count})</option>)}
                </select>
            </label>
            <label class="block">
                <span class="mb-1 block text-sm font-medium text-neutral-600 dark:text-neutral-400">排序</span>
                <select class="filter-sort w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 dark:border-neutral-700 dark:bg-neutral-950">
                    {hasTravelRanks && <option value="rank">排名优先</option>}
                    <option value="score">推荐优先</option>
                    <option value="latest">最新发布</option>
                    <option value="title">标题 A-Z</option>
                    <option value="reading">阅读时长</option>
                </select>
            </label>
        </div>
        <div class="mt-4 text-sm text-neutral-500">
            <span class="filter-count">{entries.length}</span> 篇内容
        </div>
    </div>

    <div class="filter-empty hidden rounded-xl border border-dashed border-neutral-300 p-8 text-center text-neutral-500 dark:border-neutral-700">
        没有找到匹配内容，换个关键词或标签试试。
    </div>

    <div class="filter-grid grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
        {
            entries.map((entry, index) => (
                <div
                    class="filter-item"
                    data-title={entry.data.title.toLowerCase()}
                    data-description={entry.data.description.toLowerCase()}
                    data-tags={entry.data.tags.join(" ").toLowerCase()}
                    data-tag-values={entry.data.tags.join("|")}
                    data-date={entry.data.pubDate.valueOf()}
                    data-score={getEntryScore(entry)}
                    data-rank={getTravelRank(entry) ?? 9999}
                    data-reading={parseInt(entry.meta.readingTimeText || "0", 10) || 0}
                >
                    <Card entry={entry} loading={index < 9 ? "eager" : "lazy"} />
                </div>
            ))
        }
    </div>
</section>

<script>
    const lists = document.querySelectorAll(".filterable-list");

    for (const list of lists) {
        const search = list.querySelector<HTMLInputElement>(".filter-search");
        const tag = list.querySelector<HTMLSelectElement>(".filter-tag");
        const sort = list.querySelector<HTMLSelectElement>(".filter-sort");
        const grid = list.querySelector<HTMLElement>(".filter-grid");
        const count = list.querySelector<HTMLElement>(".filter-count");
        const empty = list.querySelector<HTMLElement>(".filter-empty");
        const items = Array.from(list.querySelectorAll<HTMLElement>(".filter-item"));

        const apply = () => {
            const q = search?.value.trim().toLowerCase() ?? "";
            const selectedTag = tag?.value ?? "";
            let visible = 0;

            for (const item of items) {
                const haystack = `${item.dataset.title} ${item.dataset.description} ${item.dataset.tags}`;
                const matchesSearch = !q || haystack.includes(q);
                const matchesTag = !selectedTag || (item.dataset.tagValues ?? "").split("|").includes(selectedTag);
                const show = matchesSearch && matchesTag;
                item.hidden = !show;
                if (show) visible++;
            }

            const mode = sort?.value ?? "score";
            const sorted = [...items].sort((a, b) => {
                if (mode === "rank") return Number(a.dataset.rank) - Number(b.dataset.rank);
                if (mode === "latest") return Number(b.dataset.date) - Number(a.dataset.date);
                if (mode === "title") return (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "");
                if (mode === "reading") return Number(b.dataset.reading) - Number(a.dataset.reading);
                return Number(b.dataset.score) - Number(a.dataset.score);
            });
            sorted.forEach((item) => grid?.appendChild(item));
            sorted
                .filter((item) => !item.hidden)
                .slice(0, 9)
                .forEach((item) => {
                    const image = item.querySelector("img[loading='lazy']");
                    image?.setAttribute("loading", "eager");
                });

            if (count) count.textContent = String(visible);
            empty?.classList.toggle("hidden", visible !== 0);
        };

        search?.addEventListener("input", apply);
        tag?.addEventListener("change", apply);
        sort?.addEventListener("change", apply);
        apply();
    }
</script>
