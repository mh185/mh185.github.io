---
import type { ContentEntry, WithMeta } from "../../types";
import { entryUrl } from "../../utils/contentEnhancements";
import { cardImageSrc } from "../../utils/images";

interface Props {
    title: string;
    description: string;
    href: string;
    items: WithMeta<ContentEntry>[];
}

const { title, description, href, items } = Astro.props;
const preview = items.slice(0, 3);
---

<a href={href} class="group block rounded-xl border border-neutral-200 p-5 transition hover:bg-neutral-50 dark:border-neutral-800 dark:hover:bg-neutral-900">
    <div class="mb-4 grid grid-cols-3 gap-2">
        {
            preview.map((item) => (
                <img
                    src={cardImageSrc(item.data.image.src)}
                    alt={item.data.image.alt ?? item.data.title}
                    loading="lazy"
                    class="aspect-[4/3] rounded-lg object-cover"
                />
            ))
        }
    </div>
    <h2 class="text-xl font-bold group-hover:underline">{title}</h2>
    <p class="mt-2 line-clamp-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
        {description}
    </p>
    <div class="mt-4 text-sm font-semibold">查看专题</div>
</a>
