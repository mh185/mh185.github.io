---
import { cn } from "../../utils/styles";

interface Props {
    class?: string;
    featured?: string | number | boolean;
}

const { class: cls = "", featured } = Astro.props;
const rank = typeof featured === "string" || typeof featured === "number" ? String(featured) : "";
const label = rank ? `精选第${rank}名` : "精选";
---

<span
    class={cn(
        "mb-4 inline-block rounded-md bg-green-100 px-4 py-2 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-300",
        cls,
    )}
>
    {label}
</span>
